{
  "permissions": {
    "allow": [
      "Bash(cargo run *)",
      "Bash(pkill -f target/debug/codecrafters-redis)",
      "Bash(redis-cli -p 6379 PING)",
      "Bash(redis-cli -p 6379 ECHO hey)",
      "Bash(redis-cli -p 6379 ECHO \"hello world\")",
      "Bash(printf '*1\\\\r\\\\n$4\\\\r\\\\nPING\\\\r\\\\n')",
      "Bash(timeout 2 nc localhost 6379)",
      "Bash(printf '*2\\\\r\\\\n$4\\\\r\\\\nECHO\\\\r\\\\n$3\\\\r\\\\nhey\\\\r\\\\n')",
      "Bash(printf '*1\\\\r\\\\n$3\\\\r\\\\nFOO\\\\r\\\\n')"
    ],
    "additionalDirectories": [
      "/tmp"
    ]
  }
}
